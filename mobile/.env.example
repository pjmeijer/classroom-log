# Mobile environment variables.
#
# Copy this file to `.env` (which is gitignored) and fill in. Then restart
# Metro — Expo reads EXPO_PUBLIC_* at bundle time. The in-app Settings
# screen overrides this URL; this is the default the app falls back to
# when no setting is saved.

# Public URL of your backend (the ngrok tunnel from `ngrok http 8000`).
# Trailing slash optional. Example: https://abcd-1234.ngrok-free.app
EXPO_PUBLIC_API_BASE_URL=https://example.ngrok.app
